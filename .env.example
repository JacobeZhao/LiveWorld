# Copy this file to .env and fill in values before running.
# .env is gitignored — never commit real credentials.

# ── Logging ────────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Authentication ─────────────────────────────────────────────────────────────
# If set, every WebSocket client must send {"token":"<value>"} as first message.
# Leave unset (or remove) for open/dev mode.
# LIVEWORLD_TOKEN=change-me-before-production

# ── LLM Backends ──────────────────────────────────────────────────────────────
# Set one or more to enable real AI responses (actors default to Mock otherwise).

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (self-hosted)
# OLLAMA_URL=http://localhost:11434
