# Copy this file to .env and fill in values before running.
# .env is gitignored — never commit real credentials.

# ── Logging ────────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Required for JWT auth. Leave unset for dev/open mode (all connections accepted).
# Must be at least 32 characters for HS256 security.
# JWT_SECRET=change-me-to-a-secure-32-plus-char-string

# JWT token lifetime in seconds (default: 86400 = 24 h)
# JWT_TTL_SECS=86400

# Issue tokens via: POST http://localhost:8081/auth/token  {"user_id":"alice"}

# ── LLM Backends ──────────────────────────────────────────────────────────────
# Set one or more to enable real AI responses (actors use Mock if none configured).
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_URL=http://localhost:11434

# ── World Engine ───────────────────────────────────────────────────────────────
# In-process shards (divides x-axis). Default 1 = single-node mode.
# SHARD_COUNT=4

# ── Cross-pod State Sync (optional) ───────────────────────────────────────────
# Connect to Redis to synchronise actor snapshots across multiple pods.
# Omit or leave blank for single-pod deployment.
# REDIS_URL=redis://localhost:6379
